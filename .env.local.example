# Copy this file to .env.local and fill in all values.
# Never commit .env.local to source control.

# ── GitHub ──────────────────────────────────────────────────────────────────
# Personal access token with `repo` (read) scope for the docs repository
GITHUB_TOKEN=

# Secret shared with the GitHub webhook (used to validate X-Hub-Signature-256)
GITHUB_WEBHOOK_SECRET=

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Full URL of this deployment (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Shared passphrase — anyone who knows this can access the site
AUTH_PASSPHRASE=

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Vercel ───────────────────────────────────────────────────────────────────
# Deploy hook URL — called by the GitHub webhook handler to trigger a rebuild
VERCEL_DEPLOY_HOOK_URL=

# ── Docs repository ──────────────────────────────────────────────────────────
# The GitHub owner/repo that Vaimo Pages reads content from
DOCS_REPO=vaimo/my-docs-repo
